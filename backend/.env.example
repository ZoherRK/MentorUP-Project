# ─────────────────────────────────────────────────────────────────────────────
# MentorUP — Backend Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   php artisan key:generate
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME="MentorUP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
# Change DB_CONNECTION to 'pgsql' or 'sqlite' if needed.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mentorup
DB_USERNAME=mentorup    
DB_PASSWORD=mentorup123

# ── Session & Cache ───────────────────────────────────────────────────────────
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ── Sanctum (API tokens) ──────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to make authenticated requests.
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173

# ── CORS ─────────────────────────────────────────────────────────────────────
# React frontend dev server URL.
FRONTEND_URL=http://localhost:5173

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@mentorup.test"
MAIL_FROM_NAME="${APP_NAME}"

# ── Admin Seed Credentials ────────────────────────────────────────────────────
# Used only by AdminSeeder (php artisan db:seed).
# Change these before deploying to production!
ADMIN_EMAIL=admin@mentorup.test
ADMIN_PASSWORD=Admin1234!
